{
  "version": 2,
  "env": {
    "DATABASE_URL": "@database_url",
    "BCRYPT_ROUNDS": "10",
    "NODE_ENV": "production"
  },
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ]
}